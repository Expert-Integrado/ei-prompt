{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-ei-context.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prompt-matches-agent.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(modelo/*.md)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-ei-context.sh"
          },
          {
            "type": "command",
            "if": "Write(modelo/*.md)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-ei-context.sh"
          }
        ]
      }
    ]
  }
}
